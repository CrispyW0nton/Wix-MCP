# --- Wix App credentials (OAuth, app instance) ---
WIX_APP_ID=
WIX_APP_SECRET=
WIX_APP_PUBLIC_KEY=
# Comma-separated list of redirect URIs registered in the Wix app
WIX_REDIRECT_URIS=http://localhost:3000/oauth/callback

# --- API key admin (account-level operations) ---
# Optional. Required only for tools that declare requiredIdentity = "api_key_admin".
WIX_API_KEY=
WIX_ACCOUNT_ID=

# --- Backend service ---
WIX_BACKEND_PORT=3000
WIX_BACKEND_PUBLIC_URL=http://localhost:3000

# --- Dashboard bridge ---
DASHBOARD_BRIDGE_TOKEN=change-me-to-a-long-random-string
DASHBOARD_BRIDGE_URL=http://localhost:3001

# --- Browser worker (Playwright fallback) ---
BROWSER_WORKER_ENABLED=false
BROWSER_WORKER_URL=http://localhost:3002
BROWSER_WORKER_TOKEN=change-me-to-a-long-random-string
WIX_DASHBOARD_USER=
WIX_DASHBOARD_PASS=
PLAYWRIGHT_HEADLESS=true

# --- MCP server ---
MCP_LOG_LEVEL=info
# JSON file sink for the audit log (set empty to disable)
AUDIT_SINK_PATH=./.audit/audit.log

# --- Feature flags ---
FEATURE_BROWSER_AUTOMATION=false
FEATURE_DASHBOARD_BRIDGE=false
FEATURE_DESTRUCTIVE_WRITES=false

# --- Capability registry cache ---
CAPABILITY_CACHE_TTL_SECONDS=300
